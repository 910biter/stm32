init
reset run
sleep 2000
halt
mem2array counters 32 0x20000000 4
mem2array kernel_state 32 0x20000870 3
echo [format "task counters: task1=%u task2=%u tick=%u critical_nesting=%u saved_primask=%u raw2=0x%08x raw3=0x%08x" $counters(0) $counters(1) $kernel_state(0) $kernel_state(1) $kernel_state(2) $counters(2) $counters(3)]
shutdown
